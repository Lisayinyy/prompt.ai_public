{
  "manifest_version": 3,
  "name": "prompt.ai",
  "version": "4.7.1",
  "description": "AI Prompt Optimizer - powering AI prompts & agents",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "打开 prompt.ai"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://chat.deepseek.com/*",
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://hailuoai.com/*",
        "https://tongyi.aliyun.com/*",
        "https://yiyan.baidu.com/*",
        "https://chatglm.cn/*",
        "https://chat.mistral.ai/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*",
        "https://copilot.microsoft.com/*",
        "https://agent.minimax.io/*",
        "https://chat.z.ai/*",
        "https://qwen.ai/*",
        "https://www.genspark.ai/*",
        "https://genspark.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://prompt-optimizer-api.prompt-optimizer.workers.dev/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://kimi.moonshot.cn/*",
    "https://chat.deepseek.com/*",
    "https://gemini.google.com/*",
    "https://www.doubao.com/*",
    "https://hailuoai.com/*",
    "https://tongyi.aliyun.com/*",
    "https://yiyan.baidu.com/*",
    "https://chatglm.cn/*",
    "https://chat.mistral.ai/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*",
    "https://copilot.microsoft.com/*",
    "https://agent.minimax.io/*",
    "https://chat.z.ai/*",
    "https://qwen.ai/*",
    "https://www.genspark.ai/*",
    "https://genspark.ai/*",
    "https://vyuzkbdxsweaqftyqifh.supabase.co/*",
    "https://api.minimaxi.com/*"
  ]
}